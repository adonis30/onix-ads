{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/f/[slug]",
      "regex": "^/api/f/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/api/f/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/flyers/[id]",
      "regex": "^/api/flyers/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/flyers/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/flyers/[id]/shortlink",
      "regex": "^/api/flyers/([^/]+?)/shortlink(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/flyers/(?<nxtPid>[^/]+?)/shortlink(?:/)?$"
    },
    {
      "page": "/api/tenants/campaigns/[id]",
      "regex": "^/api/tenants/campaigns/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/tenants/campaigns/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/tenants/users/[userId]",
      "regex": "^/api/tenants/users/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/api/tenants/users/(?<nxtPuserId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/tenants/[tenantId]",
      "regex": "^/api/tenants/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtenantId": "nxtPtenantId"
      },
      "namedRegex": "^/api/tenants/(?<nxtPtenantId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/tenants/[tenantId]/subscriptions",
      "regex": "^/api/tenants/([^/]+?)/subscriptions(?:/)?$",
      "routeKeys": {
        "nxtPtenantId": "nxtPtenantId"
      },
      "namedRegex": "^/api/tenants/(?<nxtPtenantId>[^/]+?)/subscriptions(?:/)?$"
    },
    {
      "page": "/dashboard/flyers/[id]",
      "regex": "^/dashboard/flyers/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/flyers/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/analytics",
      "regex": "^/dashboard/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/analytics(?:/)?$"
    },
    {
      "page": "/dashboard/billings",
